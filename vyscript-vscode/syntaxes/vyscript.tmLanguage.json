{
  "name": "VyScript",
  "scopeName": "source.vyscript",
  "fileTypes": ["vy", "vyr"],

  "patterns": [

    {
      "name": "comment.line.vyscript",
      "match": "@.*$"
    },

    {
      "name": "string.quoted.double.vyscript",
      "begin": "\"",
      "end": "\""
    },

    {
      "name": "constant.numeric.vyscript",
      "match": "\\b\\d+\\b"
    },

    {
      "name": "keyword.control.flow.arrow.vyscript",
      "match": "->"
    },

    {
      "name": "keyword.operator.vyscript",
      "match": "(\\+|=|!|not)"
    },

    {
      "name": "keyword.declaration.var.vyscript",
      "match": "\\b(var|dat)\\b"
    },

    {
      "name": "keyword.control.vyscript",
      "match": "\\b(func|if|for|return|aslongas|otherwise|othif|public)\\b"
    },

    {
      "name": "support.function.module.vyscript",
      "match": "\\b(addInScript|alias|attempt|onfail|use|pull|edit|data)\\b"
    },

    {
      "name": "keyword.control.exception.vyscript",
      "match": "\\b(skip|end)\\b"
    },

    {
      "name": "support.function.builtin.vyscript",
      "match": "\\b(prnt|input|len|int|str)\\b"
    }

  ]
}
